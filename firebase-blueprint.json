{
  "entities": {
    "Show": {
      "title": "Show Event",
      "description": "A musical event or concert performance scheduled for HEDWIG.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the festival or event." },
        "date": { "type": "string", "format": "date-time", "description": "Date and time of the performance." },
        "city": { "type": "string", "description": "City and state/country where the event takes place." },
        "ticketLink": { "type": "string", "format": "uri", "description": "External link to purchase tickets." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "date", "city"]
    },
    "Release": {
      "title": "Music Release",
      "description": "A single, EP, or album released by HEDWIG.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the release." },
        "coverUrl": { "type": "string", "format": "uri", "description": "URL to the cover artwork image." },
        "spotifyLink": { "type": "string", "format": "uri", "description": "External link to the release on Spotify." },
        "type": { "type": "string", "enum": ["single", "ep", "album"], "description": "Type of music release." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "coverUrl", "spotifyLink"]
    },
    "GalleryPhoto": {
      "title": "Gallery Image",
      "description": "High-quality photography of HEDWIG performances or promotional shots.",
      "type": "object",
      "properties": {
        "imageUrl": { "type": "string", "format": "uri", "description": "URL to the high-resolution photo." },
        "description": { "type": "string", "description": "Short caption or description for the photo." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["imageUrl"]
    },
    "Admin": {
      "title": "System Administrator",
      "description": "User with elevated privileges to manage the site content.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin"] }
      },
      "required": ["email", "role"]
    },
    "Metric": {
      "title": "Artist Metric",
      "description": "Statistics shown in the 'Sobre' section (e.g. Total Releases, Countries).",
      "type": "object",
      "properties": {
        "label": { "type": "string", "description": "Display label (e.g. 'Releases')." },
        "value": { "type": "number", "description": "The count or value." },
        "category": { "type": "string", "enum": ["releases", "countries", "tours"] }
      },
      "required": ["label", "value"]
    }
  },
  "firestore": {
    "/shows/{showId}": {
      "schema": "Show",
      "description": "Collection of scheduled musical events."
    },
    "/releases/{releaseId}": {
      "schema": "Release",
      "description": "Collection of music releases."
    },
    "/gallery/{photoId}": {
      "schema": "GalleryPhoto",
      "description": "Grid of artist photography."
    },
    "/admins/{userId}": {
      "schema": "Admin",
      "description": "Whitelist of users with dashboard access."
    },
    "/metrics/{metricId}": {
      "schema": "Metric",
      "description": " Artist statistics and impact numbers."
    }
  }
}
